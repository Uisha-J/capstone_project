# ─── Secrets / API keys ──────────────────────────────────────
.env
.env.*
!.env.example
**/db.key
~/.aislopsquatting/

# ─── 학교 제출용 보고서 (로컬 보존) ─────────────────────────
reports/

# 키링/credential 파일들
*.pem
*.key
*.p12
*.pfx
credentials.json
service_account*.json
.netrc

# ─── Encrypted DB / runtime artifacts ───────────────────────
src/pkgsentinel/db/data/*.sqlcipher*
src/pkgsentinel/db/data/*.db
src/pkgsentinel/db/data/*.sqlite*

# Threat-intel cache (regeneratable)
src/pkgsentinel/knowledge/cache/*.json
src/pkgsentinel/knowledge/cache/*.zip

# Real-time sink output (Falco/Tetragon/STIX)
src/pkgsentinel/realtime/sinks/out/
realtime_out/

# Benchmark results (regeneratable)
src/pkgsentinel/benchmarks/results/
src/pkgsentinel/benchmarks/*.jsonl
!src/pkgsentinel/benchmarks/sample_dataset.csv

# Real-data eval — 외부 데이터셋 원본 / 다운받은 archive (gitignore)
# fixtures.json, manifest, results 는 재현 가능성을 위해 커밋한다
scripts/eval_real_data/cache/
scripts/eval_real_data/cache_lite/
scripts/eval_real_data/dataset_repo/
scripts/eval_real_data/dataset_files.txt

# ─── Copyrighted reference material ─────────────────────────
docs/papers/*.pdf
docs/papers/*.html
docs/case-studies/**/*.pdf
docs/case-studies/**/*.html
docs/case-studies/**/*.zip
docs/case-studies/**/*.tar.gz

