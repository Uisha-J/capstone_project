# pkgsentinel 어댑터 환경변수 예시
# 실제 사용 시 이 파일을 .env 로 복사하고 값을 채워넣으세요
# .env 는 .gitignore 로 보호됩니다 (시크릿 노출 방지)

# ─── 필수 ────────────────────────────────────────────────────────────
# SQLCipher DB 마스터 패스프레이즈 (32자 이상 권장)
AISLOP_DB_KEY=change-me-to-a-strong-passphrase-please

# ─── LLM (선택) ──────────────────────────────────────────────────────
# Claude API 키 — 없거나 비우면 자동으로 stub 모드 동작 (가짜 결과)
# 실제 분석을 원하면 sk-ant-api03- 로 시작하는 진짜 키 입력
ANTHROPIC_API_KEY=

# LLM 모드: auto / stub / claude
#   auto   : ANTHROPIC_API_KEY 유효성으로 자동 결정 (권장)
#   stub   : 항상 가짜 결과 (개발/테스트)
#   claude : 항상 실제 LLM 호출 (키 필수)
AISLOP_LLM_MODE=auto

# ─── 무결성 정책 (선택) ──────────────────────────────────────────────
# fast / strict / paranoid
AISLOP_INTEGRITY_MODE=strict

# 분석 결과 캐시 (true / false)
AISLOP_USE_CACHE=true

# ─── 보안 (선택) ─────────────────────────────────────────────────────
# HMAC 인증 시크릿. 비우면 인증 비활성화 (개발 모드).
# 활성화 시 모든 POST 요청에 X-AISLOPSQ-Signature 헤더 필요.
# Chrome 익스텐션 팝업과 VSCode 익스텐션 설정에 같은 값 입력해야 함.
AISLOP_HMAC_SECRET=

# ─── CORS (선택) ─────────────────────────────────────────────────────
# 기본값: claude.ai, chatgpt.com, gemini.google.com 등
# AISLOP_ALLOWED_ORIGINS=https://claude.ai,https://chatgpt.com,https://gemini.google.com
