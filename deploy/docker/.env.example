# pkgsentinel docker compose — environment 예시.
# 실제 사용 시: cp .env.example .env 후 값 채우기. .env 는 절대 commit X.

# ── 필수 ──

# SQLCipher DB 암호화 키. 32 bytes hex 권장.
#   openssl rand -hex 32
AISLOP_DB_KEY=CHANGE_ME_TO_RANDOM_HEX_64_CHARS

# HMAC 검증 secret. 클라이언트와 공유.
#   openssl rand -hex 32
PKGSENTINEL_HMAC_SECRET=CHANGE_ME_TO_RANDOM_HEX_64_CHARS

# ── 선택 (LLM 사용 시) ──

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── 포트 매핑 (host:container) ──
PKGSENTINEL_PORT=8787
